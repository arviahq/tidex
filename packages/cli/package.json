{
  "name": "@tidex/cli",
  "version": "0.0.4",
  "description": "Zero-boilerplate component explorer for React design systems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arviahq/tidex.git",
    "directory": "packages/cli"
  },
  "bin": {
    "tidex": "./bin/tidex.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config-api.js",
      "types": "./dist/config-api.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tidex/core": "workspace:*",
    "@tidex/docs": "workspace:*",
    "@tidex/manager": "workspace:*",
    "@tidex/preview": "workspace:*",
    "@tidex/scanner": "workspace:*",
    "@tidex/testing": "workspace:*",
    "@tidex/visual": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "ink": "^7.0.0",
    "react": "^19.0.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "playwright": "^1.49.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
