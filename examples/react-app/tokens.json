{
  "colors": {
    "bg": "#ffffff",
    "bgMuted": "#f8fafc",
    "bgSubtle": "#f1f5f9",
    "border": "#e2e8f0",
    "borderStrong": "#cbd5e1",
    "text": "#0f172a",
    "textMuted": "#64748b",
    "textSoft": "#94a3b8",
    "primary": "#4f46e5",
    "primarySoft": "#eef2ff",
    "primaryStrong": "#4338ca",
    "success": "#059669",
    "successSoft": "#ecfdf5",
    "warning": "#d97706",
    "warningSoft": "#fffbeb",
    "danger": "#dc2626",
    "dangerSoft": "#fef2f2",
    "info": "#2563eb",
    "infoSoft": "#eff6ff"
  },
  "spacing": {
    "0": "0px",
    "px": "1px",
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px",
    "4xl": "64px"
  },
  "typography": {
    "caption": {
      "fontSize": "12px",
      "lineHeight": "1.4",
      "fontWeight": "500"
    },
    "body": {
      "fontSize": "14px",
      "lineHeight": "1.5",
      "fontWeight": "400"
    },
    "bodyStrong": {
      "fontSize": "14px",
      "lineHeight": "1.5",
      "fontWeight": "600"
    },
    "label": {
      "fontSize": "13px",
      "lineHeight": "1.4",
      "fontWeight": "600"
    },
    "heading": {
      "fontSize": "20px",
      "lineHeight": "1.25",
      "fontWeight": "700"
    },
    "title": {
      "fontSize": "24px",
      "lineHeight": "1.2",
      "fontWeight": "700"
    },
    "display": {
      "fontSize": "32px",
      "lineHeight": "1.1",
      "fontWeight": "700",
      "letterSpacing": "-0.02em"
    }
  },
  "fontFamily": {
    "sans": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
  },
  "radius": {
    "none": "0px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "full": "9999px"
  },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px rgba(15, 23, 42, 0.06)",
    "md": "0 8px 24px rgba(15, 23, 42, 0.08)",
    "lg": "0 24px 48px rgba(15, 23, 42, 0.14)",
    "focus": "0 0 0 3px color-mix(in srgb, #4f46e5 18%, transparent)"
  },
  "border": {
    "thin": "1px",
    "medium": "2px",
    "thick": "3px"
  },
  "motion": {
    "durationFast": "120ms",
    "durationNormal": "200ms",
    "durationSlow": "320ms",
    "easeDefault": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
    "easeOut": "cubic-bezier(0, 0, 0.2, 1)"
  },
  "zIndex": {
    "base": "0",
    "dropdown": "10",
    "sticky": "20",
    "overlay": "30",
    "modal": "40",
    "toast": "50"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  }
}
